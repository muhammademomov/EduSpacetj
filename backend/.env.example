# EduSpace.tj — Backend Environment Variables
# Скопируйте этот файл как .env и заполните значения

# ── JWT ──────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-key-here-min-32-chars

# ── MySQL (локально) ────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=eduspace
DB_USER=root
DB_PASSWORD=yourpassword

# ── MySQL (Railway автоматически задаёт эти) ────
# MYSQLHOST=
# MYSQLPORT=
# MYSQLDATABASE=
# MYSQLUSER=
# MYSQLPASSWORD=
# DATABASE_URL=

# ── App ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
