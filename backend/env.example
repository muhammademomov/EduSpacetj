# EduSpace.tj — Backend Environment Variables
# Скопируйте этот файл как .env и заполните значения

# ── JWT ──────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-key-here-min-32-chars

# ── Email (Resend) ────────────────────────────────
# Получите API ключ на https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Если домен не верифицирован — используйте: onboarding@resend.dev
# Если домен верифицирован — используйте: noreply@ваш-домен.tj
FROM_EMAIL=EduSpace.tj <onboarding@resend.dev>
# URL фронтенда (для ссылки сброса пароля)
FRONTEND_URL=https://eduspacetj-production.up.railway.app

# ── MySQL (локально) ────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=eduspace
DB_USER=root
DB_PASSWORD=yourpassword

# ── MySQL (Railway автоматически задаёт эти) ────
# MYSQLHOST=
# MYSQLPORT=
# MYSQLDATABASE=
# MYSQLUSER=
# MYSQLPASSWORD=
# DATABASE_URL=

# ── App ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
